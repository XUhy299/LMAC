# 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ==================== 数据库配置 ====================
# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=agentic_rag

# 或者使用完整的 DATABASE_URL
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/agentic_rag

# ==================== Elasticsearch 配置 ====================
ES_HOST=localhost
ES_PORT=9200
ES_USER=
ES_PASSWORD=
ES_INDEX_NAME=agentic_rag_knowledge

# ES 混合检索配置
ES_VECTOR_DIM=768
ES_TOP_K=20
ES_BM25_WEIGHT=0.3
ES_VECTOR_WEIGHT=0.7
ES_MIN_SCORE=0.5

# ==================== vLLM 配置（优先使用） ====================
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY

# ==================== Ollama 配置（vLLM 不可用时自动回退） ====================
OLLAMA_BASE_URL=http://localhost:11434
DECOMPOSE_MODEL=deepseek-r1:8b
ANSWER_MODEL=qwen2.5:3b
SYNTHESIS_MODEL=qwen2.5:7b

# ==================== Embedding 模型配置 ====================
# 使用 HuggingFace 模型路径或名称
EMBEDDING_MODEL=maidalun/bce-embedding-base_v1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ==================== 知识库配置 ====================
KNOWLEDGE_BASE_DIR=./knowledge_base
KNOWLEDGE_FILE_TYPES=.pdf,.txt,.md,.docx,.doc

# ==================== 文档处理配置 ====================
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# ==================== 检索配置 ====================
TOP_K=5
RERANK_CANDIDATES=10
SIMILARITY_THRESHOLD=0.5

# ==================== API 配置 ====================
SECRET_KEY=your-secret-key-change-in-production
API_HOST=0.0.0.0
API_PORT=8000

# ==================== Streamlit 配置 ====================
STREAMLIT_PORT=8501

# ==================== 开发配置 ====================
# MOCK_LLM=true  # 启用 Mock 模式（无需真实 LLM 后端）
MAX_HISTORY_ROUNDS=10
